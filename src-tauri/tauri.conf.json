{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "expenseTracker",
  "version": "0.1.0",
  "identifier": "com.daniel.expenseTracker",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "expenseTracker",
        "width": 1920,
        "height": 1080,
        "maximized": true,
        "focus": true,
        "devtools": true
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null,
      "devCsp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}