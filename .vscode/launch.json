{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Tauri Dev with LLDB Debugger",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": [
          "build",
          "--manifest-path=${workspaceFolder}/src-tauri/Cargo.toml"
        ]
      },
      "program": "${workspaceFolder}/src-tauri/target/debug/bytevidence.exe",
      "cwd": "${workspaceFolder}/src-tauri",
      "sourceLanguages": ["rust"],
      "env": {
        "RUST_BACKTRACE": "1"
      },
      "preLaunchTask": "Start Vite for Tauri",
      "postDebugTask": "Stop Vite"
    }
  ]
}